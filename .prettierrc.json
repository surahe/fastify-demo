{
    "printWidth": 120,
    "singleQuote": true,
    "tabWidth": 4,
    "useTabs": false,
    "semi": true,
    "endOfLine": "lf",
    "trailingComma": "all",
    "proseWrap": "never",
    "overrides": [
        {
            "files": ".prettierrc",
            "options": {
                "parser": "json"
            }
        }
    ],
    "plugins": ["prettier-plugin-organize-imports", "prettier-plugin-packagejson"]
}
