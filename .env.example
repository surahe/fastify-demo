NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
REQUEST_ID_HEADER=x-request-id
TRUST_PROXY=true
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute
SWAGGER_ENABLED=true
SWAGGER_ROUTE_PREFIX=/docs
UNDER_PRESSURE_RETRY_AFTER=30
UNDER_PRESSURE_MAX_EVENT_LOOP_DELAY=1000
UNDER_PRESSURE_MAX_HEAP_USED_BYTES=0
UNDER_PRESSURE_MAX_RSS_BYTES=0
UNDER_PRESSURE_MAX_EVENT_LOOP_UTILIZATION=0.98
CACHE_TTL_MS=30000
UPSTREAM_TIMEOUT_MS=1500
UPSTREAM_RETRIES=1
UPSTREAM_RETRY_DELAY_MS=200
UPSTREAM_CIRCUIT_BREAKER_THRESHOLD=5
UPSTREAM_CIRCUIT_BREAKER_RESET_MS=10000
LIVE_API_BASE_URL=
TRADE_API_BASE_URL=
